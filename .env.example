# OMK Dashboard — environment (ADR-OMK-001 / ADR-SUPABASE-001)
# Copy to .env.local and fill. NEVER commit real values (.gitignore covers .env*).

# --- Product mode: 'internal' (OMK staff) | 'saas' (multi-tenant PME clients) ---
VITE_APP_MODE="internal"

# --- Supabase self-hosted (VPS aspace-vps) ---
# URL of the self-hosted Supabase (Caddy route or kalybana domain — confirm at deploy time).
VITE_SUPABASE_URL="https://supabase.148.230.92.235.sslip.io"
# ANON key only (public). SERVICE_ROLE_KEY stays server-side, never here.
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# --- Gemini AI (existing dependency @google/genai) ---
GEMINI_API_KEY="MY_GEMINI_API_KEY"
